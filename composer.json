{
    "name": "scandiweb/backend",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "psr-0": {
            "": "src/"
        }
    },
    "require": {
        "nikic/fast-route": "^1.3",
        "webonyx/graphql-php": "^15.2",
        "php-di/php-di": "^7.1",
        "vlucas/phpdotenv": "^5.6",
        "doctrine/orm": "^3",
        "doctrine/dbal": "^4",
        "symfony/cache": "^7",
        "doctrine/migrations": "^3.9"
    },
    "scripts": {
        "dev" : "docker compose up -d",
        "build" : "docker compose up --build -d",
        "doctrine" : "php config/database/doctrine.php",
        "seed" : "php config/database/seeds/seed.php"
    },
    "require-dev": {
        "symfony/var-dumper": "^7.4"
    }
}
